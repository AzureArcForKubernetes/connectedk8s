apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: block-dns
  namespace: azure-arc-release
spec:
  podSelector: {}        # applies to all pods in namespace
  policyTypes:
    - Egress
  egress:
    - ports:
        - port: 443      # allow HTTPS so only DNS is broken, not everything
          protocol: TCP
        - port: 80
          protocol: TCP
  # port 53 (UDP+TCP) is NOT listed → blocked